  "description": "Meraih juara 2 dalam kompetisi desain web antar SMK se-Provinsi DKI Jakarta yang diselenggarakan oleh Dinas Pendidikan.",
  "achievement_date": "2023-11-15",
  "institution_name": "Dinas Pendidikan Provinsi DKI Jakarta"
}

###

