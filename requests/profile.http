### ============================================================
### UNIVERSAL PROFILE API - REST Client Testing
### ============================================================
@baseUrl = http://localhost:8000/api

### ============================================================
### SETUP TOKEN ADMIN
### ============================================================

# @name loginAdmin
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "admin",
  "email": "admin@kompeta.test",
  "password": "admin12345"
}

###

### ============================================================
### SETUP TOKEN SEKOLAH
### ============================================================

# @name loginSekolah
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "sekolah",
  "email": "school.a@kompeta.test",
  "password": "password123"
}

###

### ============================================================
### SETUP TOKEN MITRA PERUSAHAAN
### ============================================================

# @name loginMitraPerusahaan
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "mitra",
  "email": "mitra.company.a@kompeta.test",
  "password": "password123"
}

###

### ============================================================
### SETUP TOKEN MITRA UMKM
### ============================================================

# @name loginMitraUmkm
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "mitra",
  "email": "mitra.umkm.a@kompeta.test",
  "password": "password123"
}

###

### ============================================================
### SETUP TOKEN SISWA
### ============================================================

# @name loginSiswa
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "siswa",
  "nisn": "0001234567",
  "school_origin": "SMA Negeri 1 Bogor",
  "unique_code": "BUDI0001234X9YZ"
}

###

### ============================================================
### 1. GET PROFILE ADMIN
### ============================================================

GET {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

###

### ============================================================
### 2. UPDATE PROFILE ADMIN (JSON only)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

{
  "user": {
    "name": "System Admin Kompeta"
  },
  "profile": {
    "full_name": "System Admin Kompeta"
  }
}

###

### ============================================================
### 2b. UPDATE PROFILE ADMIN (with avatar file)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}
Content-Type: multipart/form-data; boundary=----AdminUpload

------AdminUpload
Content-Disposition: form-data; name="profile[full_name]"

System Admin Kompeta
------AdminUpload
Content-Disposition: form-data; name="avatar"; filename="avatar.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
------AdminUpload--

###

### ============================================================
### 3. GET PROFILE SEKOLAH
### ============================================================

GET {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}

###

### ============================================================
### 4. UPDATE PROFILE SEKOLAH (JSON only)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}

{
  "user": {
    "email": "school.a.updated@kompeta.test"
  },
  "profile": {
    "short_description": "Sekolah vokasi unggulan untuk bidang teknologi dan bisnis.",
    "address": "Jl. Pendidikan No. 1, Bogor",
    "accreditation": "A",
    "expertise_fields": ["RPL", "TKJ", "AKL"],
    "socials": {
      "website": "https://smkn1contoh.sch.id",
      "instagram": "https://instagram.com/smkn1contoh",
      "whatsapp": "6281200001111"
    }
  }
}

###

### ============================================================
### 4b. UPDATE PROFILE SEKOLAH (with file uploads)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}
Content-Type: multipart/form-data; boundary=----SekolahUpload

------SekolahUpload
Content-Disposition: form-data; name="user[email]"

school.a.updated@kompeta.test
------SekolahUpload
Content-Disposition: form-data; name="profile[short_description]"

Sekolah vokasi unggulan untuk bidang teknologi dan bisnis.
------SekolahUpload
Content-Disposition: form-data; name="profile[accreditation]"

A
------SekolahUpload
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./sample-files/logo.jpg
------SekolahUpload
Content-Disposition: form-data; name="image_1"; filename="image1.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
------SekolahUpload
Content-Disposition: form-data; name="operational_license"; filename="license.pdf"
Content-Type: application/pdf

< ./sample-files/document.pdf
------SekolahUpload--

###

### ============================================================
### 5. GET PROFILE MITRA PERUSAHAAN
### ============================================================

GET {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginMitraPerusahaan.response.body.$.data.token}}

###

### ============================================================
### 6. UPDATE PROFILE MITRA PERUSAHAAN (JSON only)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{loginMitraPerusahaan.response.body.$.data.token}}

{
  "user": {
    "name": "PT Binajasa Sumber Sarana Tbk",
    "email": "mitra.company.updated@kompeta.test"
  },
  "profile": {
    "company_name": "PT Binajasa Sumber Sarana Tbk",
    "short_description": "Perusahaan outsourcing dan operasional bisnis.",
    "office_address": "Jakarta Selatan",
    "socials": {
      "website": "https://example.com/binajasa",
      "instagram": "https://instagram.com/binajasa",
      "linkedin": "https://linkedin.com/company/binajasa",
      "whatsapp": "6281234567890"
    },
    "industry_sector": "Outsourcing",
    "employee_total_range": "501-1000"
  }
}

###

### ============================================================
### 6b. UPDATE PROFILE MITRA PERUSAHAAN (with file uploads)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginMitraPerusahaan.response.body.$.data.token}}
Content-Type: multipart/form-data; boundary=----PerusahaanUpload

------PerusahaanUpload
Content-Disposition: form-data; name="user[name]"

PT Binajasa Sumber Sarana Tbk
------PerusahaanUpload
Content-Disposition: form-data; name="user[email]"

mitra.company.updated@kompeta.test
------PerusahaanUpload
Content-Disposition: form-data; name="profile[company_name]"

PT Binajasa Sumber Sarana Tbk
------PerusahaanUpload
Content-Disposition: form-data; name="profile[short_description]"

Perusahaan outsourcing dan operasional bisnis.
------PerusahaanUpload
Content-Disposition: form-data; name="company_logo"; filename="company-logo.png"
Content-Type: image/png

< ./sample-files/logo.jpg
------PerusahaanUpload
Content-Disposition: form-data; name="image_1"; filename="image1.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
------PerusahaanUpload
Content-Disposition: form-data; name="kemenkumham_decree"; filename="decree.pdf"
Content-Type: application/pdf

< ./sample-files/document.pdf
------PerusahaanUpload--

###

### ============================================================
### 7. GET PROFILE MITRA UMKM
### ============================================================

GET {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginMitraUmkm.response.body.$.data.token}}

###

### ============================================================
### 8. UPDATE PROFILE MITRA UMKM (JSON only)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{loginMitraUmkm.response.body.$.data.token}}

{
  "user": {
    "name": "Roti Bunda Rasa Premium",
    "email": "mitra.umkm.updated@kompeta.test"
  },
  "profile": {
    "business_name": "Roti Bunda Rasa Premium",
    "short_description": "UMKM bakery dengan fokus produksi harian.",
    "business_address": "Semarang, Jawa Tengah",
    "business_type": "Kuliner",
    "owner_personal_nib": "NIB-UMKM-001",
    "socials": {
      "instagram": "https://instagram.com/rotibundarasa",
      "whatsapp": "6281399998888"
    }
  }
}

###

### ============================================================
### 8b. UPDATE PROFILE MITRA UMKM (with file uploads)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginMitraUmkm.response.body.$.data.token}}
Content-Type: multipart/form-data; boundary=----UmkmUpload

------UmkmUpload
Content-Disposition: form-data; name="user[name]"

Roti Bunda Rasa Premium
------UmkmUpload
Content-Disposition: form-data; name="user[email]"

mitra.umkm.updated@kompeta.test
------UmkmUpload
Content-Disposition: form-data; name="profile[business_name]"

Roti Bunda Rasa Premium
------UmkmUpload
Content-Disposition: form-data; name="profile[short_description]"

UMKM bakery dengan fokus produksi harian.
------UmkmUpload
Content-Disposition: form-data; name="umkm_logo"; filename="umkm-logo.png"
Content-Type: image/png

< ./sample-files/logo.jpg
------UmkmUpload
Content-Disposition: form-data; name="owner_ktp_photo"; filename="ktp.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
------UmkmUpload
Content-Disposition: form-data; name="image_1"; filename="image1.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
------UmkmUpload--

###

### ============================================================
### 9. VALIDASI - ADMIN MENGIRIM FIELD TIDAK DIDUKUNG (expect 422)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

{
  "profile": {
    "npsn": "12345678"
  }
}

###

### ============================================================
### 10. GET PROFILE SISWA
### Cek field baru role_profile.job_applications
### ============================================================

GET {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}

###

### ============================================================
### 11. UPDATE PROFILE SISWA (JSON only)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}

{
  "profile": {
    "full_name": "Budi Santoso",
    "description": "Siswa RPL fokus backend Laravel.",
    "socials": {
      "instagram": "https://instagram.com/budisantoso",
      "whatsapp": "081234567890"
    },
    "address": "Jakarta Selatan"
  }
}

###

### ============================================================
### 12. UPDATE PROFILE SISWA (with photo upload)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: multipart/form-data; boundary=----SiswaUpload

------SiswaUpload
Content-Disposition: form-data; name="profile[description]"

Siswa RPL fokus backend Laravel.
------SiswaUpload
Content-Disposition: form-data; name="profile[socials][instagram]"

https://instagram.com/budisantoso
------SiswaUpload
Content-Disposition: form-data; name="profile[socials][whatsapp]"

081234567890
------SiswaUpload
Content-Disposition: form-data; name="photo_profile"; filename="photo.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
------SiswaUpload--

###

### ============================================================
### 13. GET PROFILE SISWA (VALIDASI JOB APPLICATIONS)
### Pastikan role_profile.job_applications berisi:
### - company_name
### - role_type
### - applied_at
### - status
### ============================================================

GET {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
