### ============================================================
### 19. APPLICATION REMINDER
###     Endpoint: GET /api/application-reminder
###     Menampilkan pesan pengingat saat melamar kerja
### ============================================================

GET {{baseUrl}}/application-reminder
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}

###

### ============================================================
### 20. AKSES ENDPOINT STUDENT DENGAN TOKEN SEKOLAH (harus 403)
###     Memastikan role guard bekerja dengan benar
### ============================================================

# @name loginSekolahForTest
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "sekolah",
  "email": "school.a@kompeta.test",
  "password": "password123"
}

###

POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSekolahForTest.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "skill",
  "title": "Ini seharusnya ditolak karena bukan siswa."
}

###

### ============================================================
###  UPDATE PORTFOLIO ITEMS
### ============================================================

### ============================================================
### 21. UPDATE PORTFOLIO - SKILL
###     Endpoint: PUT /api/student/portfolio-items/{id}
###     Gunakan ID dari response tambahSkill (#5)
### ============================================================

PUT {{baseUrl}}/student/portfolio-items/{{tambahSkill.response.body.$.data.item.id}}
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "skill",
  "title": "Laravel & Livewire"
}

###

### ============================================================
### 22. UPDATE PORTFOLIO - EXPERIENCE (partial update)
###     Gunakan ID dari response tambahExperience (#8)
### ============================================================

PUT {{baseUrl}}/student/portfolio-items/{{tambahExperience.response.body.$.data.item.id}}
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "experience",
  "title": "Magang Full-Stack Developer",
  "position": "Full-Stack Developer Intern",
  "end_date": "2023-12-31"
}

###

