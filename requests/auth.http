### ============================================================
### 3. REGISTER MITRA - UMKM
###    Endpoint : POST /api/auth/register
###    Butuh file: requests/sample-files/logo.jpg (logo umkm + ktp + image_1..image_5)
### ============================================================

# @name registerMitraUmkm
POST {{baseUrl}}/auth/register
Accept: application/json
Content-Type: multipart/form-data; boundary=BoundaryKOMPETA

--BoundaryKOMPETA
Content-Disposition: form-data; name="role"

mitra
--BoundaryKOMPETA
Content-Disposition: form-data; name="mitra_type"

umkm
--BoundaryKOMPETA
Content-Disposition: form-data; name="email"

umkm.budi@example.com
--BoundaryKOMPETA
Content-Disposition: form-data; name="password"

password123
--BoundaryKOMPETA
Content-Disposition: form-data; name="password_confirmation"

password123
--BoundaryKOMPETA
Content-Disposition: form-data; name="business_name"

UMKM Budi Jaya Elektronik
--BoundaryKOMPETA
Content-Disposition: form-data; name="owner_nik"

3201234567890001
--BoundaryKOMPETA
Content-Disposition: form-data; name="owner_personal_nib"

1234567890
--BoundaryKOMPETA
Content-Disposition: form-data; name="business_type"

Elektronik
--BoundaryKOMPETA
Content-Disposition: form-data; name="business_address"

Jl. Pasar Baru No. 5, Bandung
--BoundaryKOMPETA
Content-Disposition: form-data; name="short_description"

UMKM elektronik rumahan yang fokus pada servis dan penjualan aksesoris.
--BoundaryKOMPETA
Content-Disposition: form-data; name="umkm_logo"; filename="umkm-logo.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="owner_ktp_photo"; filename="ktp.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_1"; filename="umkm-image-1.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_2"; filename="umkm-image-2.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_3"; filename="umkm-image-3.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_4"; filename="umkm-image-4.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_5"; filename="umkm-image-5.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA--

###

### ============================================================
### 4. REGISTER - Validasi: tolak role siswa (harus 422)
### ============================================================

POST {{baseUrl}}/auth/register
Accept: application/json
Content-Type: application/json

{
  "role": "siswa",
  "email": "siswa@example.com",
  "password": "password123",
  "password_confirmation": "password123"
}

###

### ============================================================
### 5. REGISTER - Validasi: tolak role admin (harus 422)
### ============================================================

POST {{baseUrl}}/auth/register
Accept: application/json
Content-Type: application/json

{
  "role": "admin",
  "email": "admin2@example.com",
  "password": "password123",
  "password_confirmation": "password123"
}

###

### ============================================================
### 6. LOGIN - Sekolah (email + password) sebelum approval admin
###    Jalankan Register Sekolah (#1), lalu coba login ini (expected 403)
### ============================================================

# @name loginSekolah
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "sekolah",
  "email": "smk.negeri1@example.com",
  "password": "password123",
  "device_name": "rest-client"
}

###

### ============================================================
### 7. LOGIN - Mitra Perusahaan (email + password) sebelum approval admin
###    Jalankan Register Mitra Perusahaan (#2), lalu coba login ini (expected 403)
### ============================================================

# @name loginMitraPerusahaan
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "mitra",
  "email": "corp.majujaya@example.com",
  "password": "password123",
  "device_name": "rest-client"
}

###

### ============================================================
### 8. LOGIN - Mitra UMKM (email + password) sebelum approval admin
###    Jalankan Register Mitra UMKM (#3), lalu coba login ini (expected 403)
### ============================================================

# @name loginMitraUmkm
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "mitra",
  "email": "umkm.budi@example.com",
  "password": "password123",
  "device_name": "rest-client"
}

###

### ============================================================
### 9. LOGIN - Admin (seeded via DatabaseSeeder)
###     Email   : admin@kompeta.test
###     Password: admin12345
### ============================================================

# @name loginAdmin
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "admin",
  "email": "admin@kompeta.test",
  "password": "admin12345",
  "device_name": "rest-client"
}

###

### ============================================================
### 10a. APPROVE REGISTER SEKOLAH (setelah #1, pakai token admin)
### ============================================================

PATCH {{baseUrl}}/admin/registrations/{{registerSekolah.response.body.$.data.user.id}}/approve
Accept: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

###

### ============================================================
### 10b. APPROVE REGISTER MITRA PERUSAHAAN (setelah #2)
### ============================================================

PATCH {{baseUrl}}/admin/registrations/{{registerMitraPerusahaan.response.body.$.data.user.id}}/approve
Accept: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

###

### ============================================================
### 10c. APPROVE REGISTER MITRA UMKM (setelah #3)
### ============================================================

PATCH {{baseUrl}}/admin/registrations/{{registerMitraUmkm.response.body.$.data.user.id}}/approve
Accept: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

###

### ============================================================
### 11. LOGIN - Siswa (NISN + school_origin + unique_code)
###     Isi nilai unique_code dari respons tambah siswa
###     di school-students.http (#2)
###     Response tambahan onboarding:
###     - requires_skill_setup (true/false)
###     - next_step (add_skill/null)
### ============================================================

# @name loginSiswa
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "siswa",
  "nisn": "1234567890",
  "school_origin": "SMK Negeri 1 Contoh",
  "unique_code": "GANTIDULU",
  "device_name": "rest-client"
}

###

### ============================================================
### 12. LOGIN - Validasi: kredensial salah (harus 422)
### ============================================================

POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "sekolah",
  "email": "salah@example.com",
  "password": "passwordsalah",
  "device_name": "rest-client"
}

###

### ============================================================
### 13. LOGIN - Validasi: siswa dengan unique_code salah (422)
### ============================================================

POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "siswa",
  "nisn": "1234567890",
  "school_origin": "SMK Negeri 1 Contoh",
  "unique_code": "SALAHKODE",
  "device_name": "rest-client"
}

###

### ============================================================
### 14. ME - Ambil data user yang sedang login (Sekolah)
###     Token otomatis dari respons Login Sekolah (#7)
### ============================================================

GET {{baseUrl}}/auth/me
Accept: application/json
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}

###

### ============================================================
### 15. ME - Ambil data user (Mitra Perusahaan)
### ============================================================

GET {{baseUrl}}/auth/me
Accept: application/json
Authorization: Bearer {{loginMitraPerusahaan.response.body.$.data.token}}

###

### ============================================================
### 16. ME - Ambil data user (Siswa)
###     Response juga menyertakan:
###     - requires_skill_setup (true/false)
###     - next_step (add_skill/null)
### ============================================================

GET {{baseUrl}}/auth/me
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}

###

### ============================================================
### 17. LOGOUT
### ============================================================

POST {{baseUrl}}/auth/logout
Accept: application/json
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}

###

### ============================================================
### 18. ME - Akses setelah logout (harus 401)
### ============================================================

GET {{baseUrl}}/auth/me
Accept: application/json
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}

###

### ============================================================
### 19. DOWNLOAD DOKUMEN PRIVATE - SEKOLAH
###     Tipe: operational_license
### ============================================================

GET {{baseUrl}}/files/me/operational_license
Authorization: Bearer {{loginSekolah.response.body.$.data.token}}

###

### ============================================================
### 20. DOWNLOAD DOKUMEN PRIVATE - MITRA PERUSAHAAN
###     Tipe: kemenkumham_decree
### ============================================================

GET {{baseUrl}}/files/me/kemenkumham_decree
Authorization: Bearer {{loginMitraPerusahaan.response.body.$.data.token}}

###

### ============================================================
### 21. DOWNLOAD DOKUMEN PRIVATE - MITRA UMKM
###     Tipe: owner_ktp
### ============================================================

GET {{baseUrl}}/files/me/owner_ktp
Authorization: Bearer {{loginMitraUmkm.response.body.$.data.token}}

###

### ============================================================
### 22. USER ALIAS - Endpoint alias dari /auth/me
### ============================================================

GET {{baseUrl}}/user
Accept: application/json
Authorization: Bearer {{loginAdmin.response.body.$.data.token}}

###

### ============================================================
### 23. OPENAPI RAW DOCUMENT
###     Endpoint publik untuk mengambil file spesifikasi OpenAPI
### ============================================================

GET {{baseUrl}}/docs/openapi
Accept: application/yaml

###
