### ============================================================
### STUDENT PORTFOLIO API - REST Client Testing
### ============================================================
### Base URL — sesuaikan jika port berbeda
@baseUrl = http://localhost:8000/api

### ============================================================
### SETUP: Login Siswa terlebih dahulu untuk mendapatkan token
###
###        Isi nilai unique_code yang didapat dari respons
###        "Tambah Siswa" di school-students.http (#1 atau #2)
###        Cek di: student_profiles.unique_code
###
###        Jalankan request ini PERTAMA sebelum request lainnya
### ============================================================

# @name loginSiswa
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "role": "siswa",
  "nisn": "1234567890",
  "school_origin": "SMK Negeri 1 Contoh",
  "unique_code": "GANTIDULU"
}

###

### ============================================================
### CATATAN: Ganti nilai "unique_code" di atas dengan kode unik
###          yang muncul di respons tambah siswa dari sekolah.
###          Contoh respons tambah siswa:
###          {
###            "user": {
###              "student_profile": {
###                "unique_code": "ABCD1234"
###              }
###            }
###          }
### ============================================================

### ============================================================
### CHECK ONBOARDING AWAL (sebelum tambah skill)
### Endpoint: GET /api/auth/me
### Ekspektasi jika siswa belum punya skill:
### - requires_skill_setup: true
### - next_step: "add_skill"
### ============================================================

GET {{baseUrl}}/auth/me
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}

###

### ============================================================
### 1. UPDATE PROFIL SISWA (bio, kontak)
###    Endpoint: PUT /api/profile
###    Field yang dapat diisi sendiri oleh siswa:
###    - description (max 2000 karakter)
###    - phone_number
###    - address
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "profile": {
    "description": "Saya adalah siswa SMK jurusan RPL yang memiliki minat di bidang pengembangan web dan mobile. Berpengalaman dalam JavaScript, PHP, dan Python.",
    "phone_number": "081234567890",
    "address": "Jl. Siswa Berprestasi No. 5, Jakarta Selatan"
  }
}

###

### ============================================================
### 2. UPDATE PROFIL SISWA - Hanya description saja
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "profile": {
    "description": "Deskripsi portofolio yang diperbarui. Saya senang belajar teknologi baru."
  }
}

###

### ============================================================
### 3. UPDATE PROFIL SISWA - Hanya phone & address
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "profile": {
    "phone_number": "087812345678",
    "address": "Jl. Baru No. 99, Bandung"
  }
}

###

### ============================================================
### 4. UPDATE PROFIL SISWA - Validasi: description terlalu panjang (422)
### ============================================================

PUT {{baseUrl}}/profile
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "profile": {
    "description": ""
  }
}

###

### ============================================================
### 5. TAMBAH PORTFOLIO - SKILL (Keahlian)
###    Endpoint: POST /api/student/portfolio-items
###    type: "skill"
###    Field wajib: title
### ============================================================

# @name tambahSkill
POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "skill",
  "title": "Laravel PHP Framework"
}

###

### ============================================================
### 6. TAMBAH PORTFOLIO - SKILL (ke-2)
### ============================================================

POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "skill",
  "title": "JavaScript & Vue.js"
}

###

### ============================================================
### CHECK ONBOARDING SETELAH TAMBAH SKILL
### Endpoint: GET /api/auth/me
### Ekspektasi setelah minimal 1 skill tersimpan:
### - requires_skill_setup: false
### - next_step: null
### ============================================================

GET {{baseUrl}}/auth/me
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}

###

### ============================================================
### 7. TAMBAH PORTFOLIO - SKILL ke-3
### ============================================================

POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "skill",
  "title": "Figma & UI/UX Design"
}

###

### ============================================================
### 8. TAMBAH PORTFOLIO - EXPERIENCE (Pengalaman Kerja/Magang)
###    type: "experience"
###    Field wajib: title, description, position, company_name, start_date
###    Field opsional: end_date (null = masih berlangsung)
### ============================================================

# @name tambahExperience
POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "experience",
  "title": "Magang Web Developer",
  "description": "Mengembangkan fitur back-end menggunakan Laravel dan API REST. Berkolaborasi dengan tim front-end menggunakan Vue.js.",
  "position": "Back-End Developer Intern",
  "company_name": "PT Maju Jaya Teknologi",
  "start_date": "2023-07-01",
  "end_date": "2023-09-30"
}

###

### ============================================================
### 9. TAMBAH PORTFOLIO - EXPERIENCE (masih berlangsung, tanpa end_date)
### ============================================================

POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "experience",
  "title": "Freelance Web Developer",
  "description": "Membangun website profil untuk klien UMKM lokal menggunakan WordPress dan custom PHP.",
  "position": "Freelancer",
  "company_name": "Self Employed",
  "start_date": "2024-01-01",
  "end_date": null
}

###

### ============================================================
### 10. TAMBAH PORTFOLIO - EXPERIENCE - Validasi: end_date sebelum start_date (422)
### ============================================================

POST {{baseUrl}}/student/portfolio-items
Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "experience",
  "title": "Test Tanggal Salah",
  "description": "Deskripsi test.",
  "position": "Tester",
  "company_name": "Company Test",
  "start_date": "2024-06-01",
  "end_date": "2024-01-01"
}

###

