Accept: application/json
Authorization: Bearer {{loginSiswa.response.body.$.data.token}}
Content-Type: application/json

{
  "type": "achievement",
  "title": "Juara 1 Lomba Web Design Tingkat Nasional",
  "description": "Meraih juara 1 dalam kompetisi desain web antar SMK se-Indonesia."
}

