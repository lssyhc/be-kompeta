--BoundaryKOMPETA
Content-Disposition: form-data; name="password_confirmation"

password123
--BoundaryKOMPETA
Content-Disposition: form-data; name="company_name"

PT Maju Jaya Teknologi
--BoundaryKOMPETA
Content-Disposition: form-data; name="nib"

1234567890123
--BoundaryKOMPETA
Content-Disposition: form-data; name="industry_sector"

Teknologi Informasi
--BoundaryKOMPETA
Content-Disposition: form-data; name="employee_total_range"

51-200
--BoundaryKOMPETA
Content-Disposition: form-data; name="office_address"

Jl. Sudirman No. 10, Jakarta Pusat
--BoundaryKOMPETA
Content-Disposition: form-data; name="website_or_social_url"

https://www.majujaya.co.id
--BoundaryKOMPETA
Content-Disposition: form-data; name="short_description"

Perusahaan teknologi yang menyediakan solusi software untuk pendidikan dan industri.
--BoundaryKOMPETA
Content-Disposition: form-data; name="company_logo"; filename="company-logo.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_1"; filename="company-image-1.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="image_2"; filename="company-image-2.jpg"
Content-Type: image/jpeg

< ./sample-files/logo.jpg
--BoundaryKOMPETA
Content-Disposition: form-data; name="kemenkumham_decree"; filename="sk-kemenkumham.pdf"
Content-Type: application/pdf

< ./sample-files/document.pdf
--BoundaryKOMPETA--

